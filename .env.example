PORT=3000
ROBOT_TIMEZONE=Asia/Jakarta

# Default Indonesian equity because the paper balance is in rupiah.
TV_SYMBOL=IDX:BBCA
YF_SYMBOL=BBCA.JK
KLINE_INTERVAL=1D
HISTORY_FROM=2025-06-01
HISTORY_TO=2026-06-01

INITIAL_BALANCE=1500000
TRADE_ALLOCATION_PCT=0.75
MAX_POSITION_PCT=0.85
LOT_SIZE=100

ROBOT_USERNAME=admin
ROBOT_PASSWORD=admin123

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Gmail SMTP alerts. Use a Gmail app password, not your normal account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TO=

# Optional AI advisor. Default mode is local rule-based summarization.
AI_ADVISOR_MODE=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# News sentiment uses an OpenAI-compatible LM Studio endpoint by default.
LMSTUDIO_BASE_URL=http://192.168.1.51:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
LMSTUDIO_API_KEY=
LMSTUDIO_TIMEOUT_MS=75000
